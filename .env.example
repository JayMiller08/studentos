# ── StudentOS environment ────────────────────────────────────────────────
# Copy to `.env.local` for development. Set the same variables in Vercel for
# Preview and Production environments (never commit real values).
#
# When VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY are omitted, the app runs in
# "local demo mode": auth is simulated and data is persisted to this device
# only. Perfect for local UX work without a backend.

# Supabase (Project settings → API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Public URL of this deployment (used for auth email redirects)
VITE_APP_URL=http://localhost:5173

# development | preview | production
VITE_APP_ENV=development

# ── Server-side secrets (Supabase Edge Functions; set via `supabase secrets set`)
# ANTHROPIC_API_KEY=        AI study coach
# STRIPE_SECRET_KEY=        Billing
# STRIPE_WEBHOOK_SECRET=    Billing webhooks
# STRIPE_PRICE_PRO_MONTHLY= Price id for Student Pro
# STRIPE_PRICE_ELITE_MONTHLY= Price id for Student Elite
